# config/crc_150_qc_raw_only.env
# CRC full dataset (75 samples / 150 FASTQs): QC raw only

# General
THREADS=8
: "${RUN_ID:=crc150_qcraw_$(date +%Y%m%d_%H%M%S)}"

########################################
# Pipeline step toggles (1=on, 0=off)
########################################
DO_QC_RAW=1
DO_TRIM=0
DO_QC_POSTTRIM=0
DO_SALMON=0
DO_TXIMPORT=0
DO_STAR=0

############################################################
# RAW DATA STAGING (WSL I/O SAFETY)
# Policy: Never compute from /mnt/d. Use it as staging only.
############################################################

# Vendor/source drop (Windows D: mounted into WSL)
RAW_SRC_DIR="/mnt/d/oscar/pharmaron/cell_lines/batch1/X101SC251210790-Z02-J007/01.RawData"

# Local ext4 staging root (inside WSL)
RAW_LOCAL_ROOT="$PWD/data/crc_150_raw_local"

# Enable staging copy + gzip integrity gate
DO_LOCALIZE_RAW=1
DO_INTEGRITY=1

# If any FASTQ fails integrity, skip that sample and continue
SKIP_BAD_FASTQS=1

# Input FASTQ directory (symlink farm)
PILOT_FASTQ_DIR="$PWD/data/crc_150_raw"

# Outputs (roots)
QC_OUT_ROOT="$PWD/results/crc_150/qc_raw"
TRIM_OUT_ROOT="$PWD/results/crc_150/trim"
SALMON_OUT_ROOT="$PWD/results/crc_150/salmon"
TXIMPORT_OUT_ROOT="$PWD/results/crc_150/tximport"
STAR_OUT_ROOT="$PWD/results/crc_150/star"

# References (required by wrapper; unused in this config but still defined)
SALMON_INDEX="/home/summitadmin/refs/gencode_grch38/salmon_index"
TX2GENE="$HOME/refs/gencode_grch38/tx2gene.noversion.tsv"
STAR_INDEX="$PWD/star_pilot/index"
