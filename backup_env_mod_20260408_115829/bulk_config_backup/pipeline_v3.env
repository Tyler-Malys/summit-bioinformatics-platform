# config/pipeline_v2.env
#
# Bulk RNA-seq unified configuration (v2)
# Date: 2026-03-18
#
# Intent:
# - practical first implementation of the unified schema
# - shell-compatible for wrapper loading
# - covers full active bulk RNA-seq pipeline
# - keeps stable engineering conventions in documentation, not as user-facing knobs

########################################
# RUN
########################################

PIPELINE_NAME="bulk_rnaseq"
RUN_MODE="pilot"

# Leave blank to let wrapper generate one
RUN_ID=""

# Wrapper-level execution behavior
DRY_RUN=0

# Stage toggles
DO_LOCALIZE_RAW=0
DO_INTEGRITY_CHECK=0
DO_QC_RAW=1
DO_TRIM=1
DO_QC_POSTTRIM=1
DO_SALMON=1
DO_TXIMPORT=1
DO_STAR=1

DO_BUILD_ANALYSIS_OBJECT=1
DO_VST_DIAGNOSTICS=1
DO_PCA_QC=1
DO_DIFFERENTIAL_EXPRESSION=1
DO_GSEA=1
DO_GSEA_SUMMARY=1
DO_GSEA_HEATMAPS=1

# Input selection for downstream sequence-processing stages
SALMON_INPUT_MODE="trimmed"   # raw | trimmed
STAR_INPUT_MODE="trimmed"     # raw | trimmed

########################################
# INPUT
########################################

PIPELINE_ROOT="${PIPELINE_ROOT:-$PWD}"

# Primary sequence input
FASTQ_DIR="${PIPELINE_ROOT}/data/pilot_subset_02"

# Optional localization / staging
RAW_SOURCE_DIR="${RAW_SOURCE_DIR:-$FASTQ_DIR}"
RAW_LOCAL_ROOT="${PIPELINE_ROOT}/data/raw_local"

# Optional explicit metadata / analysis inputs
SAMPLE_SHEET=""
METADATA_FILE=""

# Optional direct downstream inputs
# Leave empty when running end-to-end from FASTQs
COUNTS_MATRIX=""
DDS_OBJECT=""
VSD_OBJECT=""

# Metadata parsing behavior
INFER_METADATA_FROM_SAMPLE_NAMES=1
SAMPLE_NAME_CELL_LINE_RULE="prefix_before_first_underscore"
SAMPLE_NAME_DOSE_RULE="token_matching_D[0-9]+|DMSO"
SAMPLE_NAME_REPLICATE_RULE="final_numeric_token"

# Comma-separated values
# Multi-value fields are comma-separated with no spaces unless parser trims whitespace.
ALLOWED_SAMPLE_GROUPS="Hep,SW48,SW480,SW1116"
EXCLUDED_SAMPLE_GROUPS="THLE_2"

########################################
# REF
########################################

SPECIES="human"
GENOME_BUILD="GRCh38"

SALMON_INDEX="/home/summitadmin/refs/gencode_grch38/salmon_index"
STAR_INDEX="${PIPELINE_ROOT}/star_pilot/index"
TX2GENE="$HOME/refs/gencode_grch38/tx2gene.noversion.tsv"

# Downstream annotation / enrichment
GENE_ANNOTATION_DB="org.Hs.eg.db"
GMT_FILE=""
GMT_COLLECTION_NAME=""

########################################
# RESOURCE
########################################

THREADS=8

FASTQC_BIN="/home/summitadmin/miniconda3/envs/bulk_qc_tools/bin/fastqc"
MULTIQC_BIN="/home/summitadmin/miniconda3/envs/bulk_qc_tools/bin/multiqc"

MEMORY_GB=""
TMP_DIR=""

# Optional R library override; leave empty to use default environment behavior
R_LIBPATHS=""

########################################
# OUTPUT
########################################

RUNS_ROOT="${PIPELINE_ROOT}/runs"

QC_ROOT="${PIPELINE_ROOT}/results/qc"
TRIM_ROOT="${PIPELINE_ROOT}/results/trimmed"
SALMON_ROOT="${PIPELINE_ROOT}/results/salmon"
TXIMPORT_ROOT="${PIPELINE_ROOT}/results/tximport"
STAR_ROOT="${PIPELINE_ROOT}/results/star"

ANALYSIS_OBJECT_ROOT="${PIPELINE_ROOT}/analysis_objects"
DE_ROOT="${PIPELINE_ROOT}/results/de"
GSEA_ROOT="${PIPELINE_ROOT}/results/gsea"
GSEA_SUMMARY_ROOT="${PIPELINE_ROOT}/results/gsea/summary"
GSEA_FIGURE_ROOT="${PIPELINE_ROOT}/results/gsea/figures"
DOWNSTREAM_QC_ROOT="${PIPELINE_ROOT}/results/qc"

########################################
# QC
########################################

SKIP_BAD_FASTQS=1

GENE_FILTER_MIN_COUNT=10
GENE_FILTER_MIN_SAMPLES=2
REMOVE_EMPTY_GENE_IDS=1
ROUND_COUNTS_TO_INTEGER=1

VST_BLIND=0
PCA_GROUP_VARIABLE="cell_line"

########################################
# ANALYSIS
########################################

# DESeq2 object build
DESEQ2_DESIGN_FORMULA="~ cell_line"
DE_REFERENCE_LEVEL="Hep"
RUN_DESEQ_DURING_OBJECT_BUILD=1
CREATE_VST_OBJECT=1

# Differential expression
DE_CONTRAST_VARIABLE="cell_line"
# Multi-value fields are comma-separated with no spaces unless parser trims whitespace.
DE_CONTRASTS="SW48_vs_Hep,SW480_vs_Hep,SW1116_vs_Hep"

RUN_POOLED_CONTRAST=1
POOLED_GROUP_NAME="CRC"
POOLED_REFERENCE_NAME="Hep"
POOLED_DESIGN_FORMULA="~ group2"

DE_SHRINK_LFC=1
DE_SHRINK_METHOD="apeglm"
DE_SIGNIFICANCE_ALPHA=0.05
DE_SUMMARY_LFC_THRESHOLD=1.0

EXPORT_UNSHRUNK_RESULTS=1
EXPORT_SHRUNK_RESULTS=1

# GSEA
GSEA_DE_INPUT_FILE=""
GSEA_RUN_ID=""
GSEA_RANK_BY="stat"
GSEA_ALLOW_RANK_COLUMN_AUTO_SWITCH=1
GSEA_MIN_SIZE=15
GSEA_MAX_SIZE=500
GSEA_TOP_PLOT_PADJ_THRESHOLD=0.05
GSEA_TOP_PLOT_MAX_PATHWAYS=30
GSEA_MAP_ENSEMBL_TO_SYMBOL=1

# GSEA summary / reporting
GSEA_FILE_PATTERN="_fgsea_stat.csv$"
EXPLICIT_GSEA_RUNS=""
GSEA_SUMMARY_PADJ_THRESHOLD=0.05
# Multi-value fields are comma-separated with no spaces unless parser trims whitespace.
GSEA_COLLECTIONS="Hallmark,Reactome"
GSEA_REQUIRED_SHARED_CONTRAST_COUNT=4
GSEA_REQUIRE_SAME_DIRECTION=1
# Multi-value fields are comma-separated with no spaces unless parser trims whitespace.
GSEA_CONTRAST_ORDER="crc_vs_hep_pooled,sw48_vs_hep,sw480_vs_hep,sw1116_vs_hep"
GSEA_POOLED_CONTRAST_LABEL="crc_vs_hep_pooled"
GSEA_HALLMARK_TOP_N=10
GSEA_REACTOME_TOP_N=20
GENERATE_NES_MATRICES=1

# GSEA heatmaps
GSEA_HEATMAP_CAP=3
GSEA_REACTOME_TOP_N_FOR_HEATMAP=40

########################################
# LOG
########################################

WRITE_WRAPPER_LOG=1
WRAPPER_LOG_NAME="wrapper.log"

WRITE_RUN_MANIFEST=1
WRITE_PIPELINE_VERSION=1
WRITE_SOFTWARE_VERSIONS=1
WRITE_START_END_STATUS=1
WRITE_STAGE_RUN_INFO=1

# Keep current split behavior for now:
# wrapper metadata + per-stage run_info.txt
CENTRALIZE_STAGE_METADATA=0

WRITE_PDF_FIGURES=1
WRITE_PNG_FIGURES=1

########################################
# BACKWARD-COMPATIBILITY ALIASES
########################################

# Transitional aliases for existing wrapper/stage compatibility; canonical names are above.

# Wrapper v2 legacy names
DO_INTEGRITY="${DO_INTEGRITY_CHECK}"
PILOT_FASTQ_DIR="${FASTQ_DIR}"

QC_OUT_ROOT="${QC_ROOT}"
TRIM_OUT_ROOT="${TRIM_ROOT}"
SALMON_OUT_ROOT="${SALMON_ROOT}"
TXIMPORT_OUT_ROOT="${TXIMPORT_ROOT}"
STAR_OUT_ROOT="${STAR_ROOT}"

RAW_SRC_DIR="${RAW_SOURCE_DIR}"

SALMON_INPUT="${SALMON_INPUT_MODE}"
STAR_INPUT="${STAR_INPUT_MODE}"

########################################
# FIXED PIPELINE CONVENTIONS (DOCUMENTATION)
########################################

# These are enforced by pipeline code and are not yet configurable.

# Input conventions
# - Bulk RNA-seq input is paired-end
# - Accepted FASTQ extensions: .fq.gz, .fastq.gz
# - Mate suffixes: _1 / _2

# Run directory structure
# - input/
# - working/
# - logs/
# - qc/
# - outputs/
# - downstream/
# - final/
# - run_metadata/

# Stage output naming
# - qc_, trim_, qc_posttrim_, salmon_, txi_, star_

# Tool behavior (current defaults)
# - fastp: paired-end adapter autodetection
# - Salmon: library autodetect (-l A), validateMappings
# - STAR: zcat input, sorted BAM output, GeneCounts enabled

# tximport behavior
# - expects per-sample Salmon quant.sf
# - strips transcript version suffixes

# GSEA assumptions
# - DE genes assumed Ensembl-derived
# - Ensembl IDs mapped to HGNC symbols
# - Symbol-based GMT files expected
