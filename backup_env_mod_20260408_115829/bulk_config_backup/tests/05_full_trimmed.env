# config/tests/05_full_trimmed.env
THREADS=8
: "${RUN_ID:=t05_$(date +%Y%m%d_%H%M%S)}"

DO_QC_RAW=1
DO_TRIM=1
DO_QC_POSTTRIM=1
DO_SALMON=1
DO_TXIMPORT=1
DO_STAR=1

SALMON_INPUT=trimmed
STAR_INPUT=trimmed

PILOT_FASTQ_DIR="$PWD/data/pilot_onepair"

QC_OUT_ROOT="$PWD/results/tests/05_full_trimmed/qc"
TRIM_OUT_ROOT="$PWD/results/tests/05_full_trimmed/trim"
SALMON_OUT_ROOT="$PWD/results/tests/05_full_trimmed/salmon"
TXIMPORT_OUT_ROOT="$PWD/results/tests/05_full_trimmed/tximport"
STAR_OUT_ROOT="$PWD/results/tests/05_full_trimmed/star"

SALMON_INDEX="/home/summitadmin/refs/gencode_grch38/salmon_index"
TX2GENE="$HOME/refs/gencode_grch38/tx2gene.noversion.tsv"
STAR_INDEX="$PWD/star_pilot/index"
