# config/tests/02_trim_and_postqc_only.env
THREADS=8
: "${RUN_ID:=t02_$(date +%Y%m%d_%H%M%S)}"

DO_QC_RAW=0
DO_TRIM=1
DO_QC_POSTTRIM=1
DO_SALMON=0
DO_TXIMPORT=0
DO_STAR=0

PILOT_FASTQ_DIR="$PWD/data/pilot_onepair"

QC_OUT_ROOT="$PWD/results/tests/02_trim_and_postqc_only/qc"
TRIM_OUT_ROOT="$PWD/results/tests/02_trim_and_postqc_only/trim"
SALMON_OUT_ROOT="$PWD/results/tests/02_trim_and_postqc_only/salmon"
TXIMPORT_OUT_ROOT="$PWD/results/tests/02_trim_and_postqc_only/tximport"
STAR_OUT_ROOT="$PWD/results/tests/02_trim_and_postqc_only/star"

SALMON_INDEX="/home/summitadmin/refs/gencode_grch38/salmon_index"
TX2GENE="$HOME/refs/gencode_grch38/tx2gene.noversion.tsv"
STAR_INDEX="$PWD/star_pilot/index"
