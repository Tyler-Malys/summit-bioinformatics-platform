# Known-good example config used for backend comparison testing
# Contains environment-specific run directories from validation runs
# Not intended as the generic distributed template
#
# template_scrnaseq.env
#
# Canonical scRNA-seq pipeline configuration template
#
# Usage:
#   scripts/run_scrnaseq_wrapper.sh <config.env> [engine] [manifest]
#
# Notes:
# - Wrapper may override ENGINE and MANIFEST_FILE from CLI arguments.
# - Leave RUN_ID blank to auto-generate.
# - Core stages are preprocess, qc, downstream_core.
# - Later biological interpretation/reporting stages are optional.

########################################
# RUN
########################################

PIPELINE_NAME="scrnaseq"
RUN_MODE="template"
RUN_ID=""
DRY_RUN=0

########################################
# INPUT
########################################

PIPELINE_ROOT="/home/summitadmin/bioinformatics_projects/pipelines/scrnaseq"
MANIFEST_FILE="${PIPELINE_ROOT}/metadata/starsolo_runs.tsv"
FASTQ_ROOT=""
COMPARE_CELLRANGER_SOURCE_RUN_DIR="/home/summitadmin/bioinformatics_projects/pipelines/scrnaseq/runs/scrna_cellranger_20260324_120132"
COMPARE_STARSOLO_SOURCE_RUN_DIR="/home/summitadmin/bioinformatics_projects/pipelines/scrnaseq/runs/scrna_starsolo_20260324_110215"
SPECIES="human"

########################################
# REF
########################################

REF_ROOT="${PIPELINE_ROOT}/ref"
STAR_INDEX="${REF_ROOT}/star_index"
CELLRANGER_REF="${REF_ROOT}/cellranger_ref"
CELLRANGER_BIN="/home/summitadmin/bioinformatics_tools/cellranger-10.0.0/bin/cellranger"

########################################
# RESOURCE
########################################

THREADS=8
MEMORY_GB=64
RSCRIPT_BIN="/home/summitadmin/miniconda3/envs/scrna_dbl/bin/Rscript"
SCDBLFINDER_RSCRIPT_BIN="/home/summitadmin/miniconda3/envs/scrna_dbl/bin/Rscript"

########################################
# ENGINE
########################################

# Supported: cellranger | starsolo
ENGINE="starsolo"

########################################
# OUTPUT
########################################

RUNS_ROOT="${PIPELINE_ROOT}/runs"
WRITE_REPO_LEVEL_EXPORTS=0

########################################
# STAGE TOGGLES
########################################

RUN_PREPROCESS=0
RUN_QC=0
RUN_DOWNSTREAM_CORE=0

RUN_MARKERS=0
RUN_ANNOTATION=0
RUN_DIFFERENTIAL=0
RUN_PATHWAY=0
RUN_VISUALIZATION=0
RUN_REPORT=0
RUN_COMPARE_BACKENDS=1

########################################
# QC PARAMETERS
########################################

QC_MATRIX_TYPE="raw"
QC_EMPTYDROPS_LOWER=100
QC_EMPTYDROPS_FDR=0.01
QC_MIN_COUNTS=500
QC_MIN_GENES=200
QC_MAX_PCT_MITO=20
QC_RANDOM_SEED=123

########################################
# DOWNSTREAM CORE PARAMETERS
########################################

N_TOP_HVGS=2000
N_PCS=30
PC_COVARIATE_N=10
GRAPH_K=20
CLUSTER_ALGORITHM="louvain"

UMAP_N_NEIGHBORS=30
UMAP_MIN_DIST=0.3
UMAP_METRIC="cosine"

TSNE_PERPLEXITY=30
TSNE_DIMS=2

########################################
# OPTIONAL ANALYSIS PARAMETERS
########################################

CLUSTER_COLUMN="cluster_pca_regressed"

DE_GROUP_A="B cells"
DE_GROUP_B="T cells"

FGSEA_SPECIES="Homo sapiens"
FGSEA_MIN_SIZE=10
FGSEA_MAX_SIZE=500

########################################
# LOGGING
########################################

WRITE_WRAPPER_LOG=1
WRAPPER_LOG_NAME="wrapper.log"
