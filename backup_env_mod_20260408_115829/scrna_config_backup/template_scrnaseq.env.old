# template_scrnaseq.env
#
# Template scRNA-seq configuration
#
# Usage:
# - Copy this file and modify values for your dataset
# - Used with scripts/run_scrnaseq_wrapper_v3.sh

########################################
# RUN
########################################

PIPELINE_NAME="scrnaseq"
RUN_MODE="template"

# Leave blank to auto-generate
RUN_ID=""

# Execution behavior
DRY_RUN=0

########################################
# INPUT
########################################

PIPELINE_ROOT="/path/to/pipelines/scrnaseq"

# FASTQ root (dataset-specific)
FASTQ_ROOT="/path/to/fastq_root"

# Manifest file (TSV)
MANIFEST_FILE="/path/to/manifest.tsv"

########################################
# REF
########################################

REF_ROOT="/path/to/ref"

STAR_INDEX="/path/to/star_index"
CELLRANGER_REF="/path/to/cellranger_ref"

########################################
# RESOURCE
########################################

THREADS=8
MEMORY_GB=64

########################################
# ENGINE
########################################

# cellranger | starsolo
ENGINE="cellranger"

########################################
# OUTPUT
########################################

RUNS_ROOT="${PIPELINE_ROOT}/runs"

########################################
# LOG
########################################

WRITE_WRAPPER_LOG=1
WRAPPER_LOG_NAME="wrapper.log"
