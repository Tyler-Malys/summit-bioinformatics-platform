# scrna_pbmc1k_cellranger.env
#
# Example scRNA-seq config (Cell Ranger)
# Dataset: PBMC 1k

########################################
# RUN
########################################

PIPELINE_NAME="scrnaseq"
RUN_MODE="validation"
RUN_ID=""
DRY_RUN=0

########################################
# INPUT
########################################

PIPELINE_ROOT="/home/summitadmin/bioinformatics_projects/pipelines/scrnaseq"
MANIFEST_FILE="${PIPELINE_ROOT}/metadata/cellranger_runs.tsv"
FASTQ_ROOT="${PIPELINE_ROOT}/data/fastq/pbmc_1k_v3/pbmc_1k_v3_fastqs"
SPECIES="human"

########################################
# REF
########################################

REF_ROOT="/home/summitadmin/refs"
ORGANISM="human"
GENOME_BUILD="grch38"
ANNOTATION_VERSION="gencode_v49"

STAR_INDEX=""
CELLRANGER_REF=""
CELLRANGER_BIN="/home/summitadmin/bioinformatics_tools/cellranger-10.0.0/bin/cellranger"

########################################
# RESOURCE
########################################

THREADS=8
MEMORY_GB=64
RSCRIPT_BIN="/home/summitadmin/miniconda3/envs/scrnaseq_env/bin/Rscript"
SCDBLFINDER_RSCRIPT_BIN="/home/summitadmin/miniconda3/envs/scrna_dbl/bin/Rscript"

########################################
# ENGINE
########################################

ENGINE="cellranger"

########################################
# OUTPUT
########################################

RUNS_ROOT="${PIPELINE_ROOT}/runs"
WRITE_REPO_LEVEL_EXPORTS=0

########################################
# STAGE TOGGLES
########################################

RUN_PREPROCESS=1
RUN_QC=1
RUN_DOWNSTREAM_CORE=1
PREPROCESS_SOURCE_RUN_DIR=""

RUN_MARKERS=0
RUN_ANNOTATION=0
RUN_DIFFERENTIAL=0
RUN_PATHWAY=0
RUN_VISUALIZATION=0
RUN_REPORT=0
RUN_COMPARE_BACKENDS=0

########################################
# QC PARAMETERS
########################################

QC_MATRIX_TYPE="raw"
QC_EMPTYDROPS_LOWER=100
QC_EMPTYDROPS_FDR=0.01
QC_MIN_COUNTS=500
QC_MIN_GENES=200
QC_MAX_PCT_MITO=20
QC_RANDOM_SEED=123

########################################
# DOWNSTREAM CORE PARAMETERS
########################################

N_TOP_HVGS=2000
N_PCS=30
PC_COVARIATE_N=10
GRAPH_K=20
CLUSTER_ALGORITHM="louvain"

UMAP_N_NEIGHBORS=30
UMAP_MIN_DIST=0.3
UMAP_METRIC="cosine"

TSNE_PERPLEXITY=30
TSNE_DIMS=2

########################################
# OPTIONAL ANALYSIS PARAMETERS
########################################

CLUSTER_COLUMN="cluster_pca_regressed"

DE_GROUP_A="B cells"
DE_GROUP_B="T cells"

FGSEA_SPECIES="Homo sapiens"
FGSEA_MIN_SIZE=10
FGSEA_MAX_SIZE=500

########################################
# LOGGING
########################################

WRITE_WRAPPER_LOG=1
WRAPPER_LOG_NAME="wrapper.log"
