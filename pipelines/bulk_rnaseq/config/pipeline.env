# config/pipeline.env

# General
THREADS=8
: "${RUN_ID:=$(date +%Y%m%d_%H%M%S)}"

########################################
# Pipeline step toggles (1=on, 0=off)
########################################
DO_QC_RAW=1
DO_TRIM=1
DO_QC_POSTTRIM=1
DO_SALMON=1
DO_TXIMPORT=1
DO_STAR=1

# Pilot inputs
PILOT_FASTQ_DIR="$PWD/data/pilot_subset_02"

# Outputs (roots)
QC_OUT_ROOT="$PWD/results/qc_test"
TRIM_OUT_ROOT="$PWD/results/trim_test"
SALMON_OUT_ROOT="$PWD/results/salmon_test"
TXIMPORT_OUT_ROOT="$PWD/results/tximport_test"
STAR_OUT_ROOT="$PWD/results/star_test"

# References
SALMON_INDEX="/home/summitadmin/refs/gencode_grch38/salmon_index"
TX2GENE="$HOME/refs/gencode_grch38/tx2gene.noversion.tsv"
STAR_INDEX="$PWD/star_pilot/index"
