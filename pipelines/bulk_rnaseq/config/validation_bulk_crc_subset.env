DO_QC_RAW=1
DO_TRIM=1
DO_QC_POSTTRIM=1
DO_SALMON=1
SALMON_INPUT="trimmed"
DO_TXIMPORT=1
DO_STAR=0
STAR_INPUT="trimmed"

PILOT_FASTQ_DIR="$PWD/data/validation_crc_subset"

QC_OUT_ROOT="$PWD/results/tests/validation_bulk_crc_subset/qc"
