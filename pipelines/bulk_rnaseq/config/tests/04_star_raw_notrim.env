# config/tests/04_star_raw_notrim.env
THREADS=8
: "${RUN_ID:=t04_$(date +%Y%m%d_%H%M%S)}"

DO_QC_RAW=0
DO_TRIM=0
DO_QC_POSTTRIM=0
DO_SALMON=0
DO_TXIMPORT=0
DO_STAR=1

STAR_INPUT=raw

PILOT_FASTQ_DIR="$PWD/data/pilot_onepair"

QC_OUT_ROOT="$PWD/results/tests/04_star_raw_notrim/qc"
TRIM_OUT_ROOT="$PWD/results/tests/04_star_raw_notrim/trim"
SALMON_OUT_ROOT="$PWD/results/tests/04_star_raw_notrim/salmon"
TXIMPORT_OUT_ROOT="$PWD/results/tests/04_star_raw_notrim/tximport"
STAR_OUT_ROOT="$PWD/results/tests/04_star_raw_notrim/star"

SALMON_INDEX="/home/summitadmin/refs/gencode_grch38/salmon_index"
TX2GENE="$HOME/refs/gencode_grch38/tx2gene.noversion.tsv"
STAR_INDEX="$PWD/star_pilot/index"
