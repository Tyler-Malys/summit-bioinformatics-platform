# scrna_pbmc1k_cellranger.env
#
# Example scRNA-seq config (Cell Ranger)
# Dataset: PBMC 1k

PIPELINE_NAME="scrnaseq"
RUN_MODE="example"

RUN_ID=""

PIPELINE_ROOT="/home/summitadmin/bioinformatics_projects/pipelines/scrnaseq"

FASTQ_ROOT="/home/summitadmin/bioinformatics_projects/pipelines/scrnaseq/data/fastq/pbmc_1k_v3/pbmc_1k_v3_fastqs"
MANIFEST_FILE="/home/summitadmin/bioinformatics_projects/pipelines/scrnaseq/metadata/cellranger_runs.tsv"

REF_ROOT="/home/summitadmin/bioinformatics_projects/pipelines/scrnaseq/ref"

CELLRANGER_REF="${REF_ROOT}/cellranger_ref"
STAR_INDEX="${REF_ROOT}/star_index"

THREADS=8
MEMORY_GB=64

ENGINE="cellranger"

RUNS_ROOT="${PIPELINE_ROOT}/runs"
